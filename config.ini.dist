;===============================================================================
; MAIN AUTOMATION - CONFIGURATION FILE
;===============================================================================
;
; PRIMERA VEZ / NUEVA PC:
; 1. El script detectará automáticamente aplicaciones comunes (Chrome, VS Code, etc.)
; 2. Te mostrará qué aplicaciones no fueron encontradas
; 3. Podés configurar manualmente editando este archivo o dejarás que el script pregunte
; 4. Las features de aplicaciones no disponibles se deshabilitarán automáticamente
;
; PATHS OPCIONALES vs CRÍTICOS:
; - La mayoría de paths son OPCIONALES (el script funciona sin ellos)
; - Solo configurá los que realmente usás
; - Paths vacíos = feature deshabilitada (sin errores)
;
;===============================================================================

[paths]
; System-wide paths (updated on initialization)
user_home=
user_documents=
user_appdata=
user_localappdata=
program_files=
program_files_x86=

[general]
lastDate=
hidePathsSummary=0  ; 0 = mostrar diálogo de paths faltantes, 1 = ocultar

[variables]
cursorKeysEnabled=1
logVisibility=0

[audioDeviceFavorites]
; Se llena automáticamente desde la interfaz.

[web-clipboard]
room=
base_url=https://web-clipboard.jpsala.workers.dev

[appInstances]

[desktop]
; NOTA: Estos paths se auto-detectan si están vacíos o son inválidos
; Solo necesitás configurarlos si están en ubicaciones no estándar

; Base directories
tools_dir=C:\tools
dev_dir=C:\dev
scripts_dir=C:\dev\scripts\bin

; Tools and utilities (opcionales)
tail_exe=C:\tools\Tail.exe
nircmd_exe=C:\tools\nircmd.exe
notifu_exe=C:\tools\notifu\notifu.exe
scrcpy_launcher=C:\tools\scrcpy\scrcpy-noconsole.vbs
phone_serial=
tablet_serial=
strokesplus_exe=C:\tools\strokesPlus\StrokesPlus.net.exe
strokesplus_dir=C:\tools\strokesPlus
xyplorer_path=C:\tools\XYplorer-portable\XYplorer.exe
log_file=C:\dev\scripts\bin\log.txt

; Application paths (auto-detectados si están vacíos)
; Solo cambiá si tu instalación está en una ubicación custom
whatsapp_path=
cursor_path=
vscode_path=
vivaldi_path=
vivaldi_local_path=
chrome_path=
zen_path=

[work]
; Add your work machine-specific paths here if needed
; Base directories
tools_dir=C:\tools
dev_dir=C:\dev
scripts_dir=C:\dev\scripts\bin

; Tools and utilities
tail_exe=C:\tools\Tail.exe
nircmd_exe=C:\tools\nircmd.exe
notifu_exe=C:\tools\notifu\notifu.exe
log_file=C:\dev\scripts\bin\log.txt

; Application paths
cursor_path=C:\Program Files\cursor\Cursor.exe
vscode_path=C:\Users\<USERNAME>\AppData\Local\Programs\Microsoft VS Code\Code.exe
chrome_path=C:\Program Files\Google\Chrome\Application\chrome.exe

[machines]
; Map computer names to device sections
; Format: computerName=sectionName
; The section name determines which [section] in config.ini provides paths
; Fallback: "desktop" if computer name not found
ZENBOOK=notebook
CIDEV06=remote
gordos=gordos
AR-IT31927=work
avdp-1310=carnival

[vivaldi-profiles]
; Format: key=profileDir|userDataDir|extraFlags
; userDataDir and extraFlags are optional (leave empty for browser default)
main=Profile 1||
carnival=Carnival|%LocalAppData%\Vivaldi\User Data|
youtube=Youtube|%LocalAppData%\Vivaldi\User Data|
mainalt=Main.alt||
gemin=Gemin||
ai=AI|%LocalAppData%\Vivaldi\User Data|
trading=Trading||
gordos=Gordos||
books=Books|%UserProfile%\vivaldi-profiles|
debug=Debug||--no-first-run

[chrome-profiles]
work=Work|%LocalAppData%\Google\Chrome\User Data|
debug=Profile 3|%LocalAppData%\Chrome Debug|--flag-switches-begin --flag-switches-end --origin-trial-disabled-features=CanvasTextNg\|WebAssemblyCustomDescriptors
main=Profile 1||

[vivaldi-local-profiles]
main=Main||
ai=AI||
gordos=Gordos||

[bookmarkHotkeys]
; Hotkey definitions for window bookmarks
; Format: index=hotkeyString|enabled (1=active, 0=disabled)
; Modifiers: # = Win, ! = Alt, ^ = Ctrl, + = Shift
; These are seeded with defaults on first run.
1=#1|1
2=#2|1
3=#3|1
4=#4|1
5=#5|1
6=#6|1
7=#7|1
8=#8|1
9=#9|1
10=#0|1
11=#b|1
12=#d|1
13=#e|1
14=#f|1
15=#g|1
16=#i|1
17=#t|1
18=#q|1
19=#z|1
20=#v|1
21=#x|1
22=!#a|1
23=!#d|1
24=!#e|1
25=!#f|1
26=!#g|1
27=!#q|1
28=!#r|1
29=!#v|1
30=!#x|1
31=!#w|1
32=!#z|1

[bookmarks]
; Window bookmarks format: key=ahk_id|title
; Example: 1=ahk_id 12345|My Browser Window

[windowAliases]
; Window aliases for quick access
; Example: vivaldi-main=ahk_id 198340
